APP_DOMAIN=example.com
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=
FACT_CHECK_EXTRACTION_MODEL=gemini-2.5-flash-lite
GEMINI_FACT_CHECK_MODEL=gemini-2.5-flash-lite
AUTH_SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=replace_with_a_strong_admin_password
AUTH_ADMIN_DISPLAY_NAME=Admin
AUTH_ADVANCED_USERNAME=
AUTH_ADVANCED_PASSWORD=
AUTH_ADVANCED_DISPLAY_NAME=Advanced User
AUTH_BASIC_USERNAME=
AUTH_BASIC_PASSWORD=
AUTH_BASIC_DISPLAY_NAME=Basic User
AUTH_COOKIE_SECURE=auto
PRODUCTION_SSH_TARGET=root@your_server_ip
PRODUCTION_SSH_PORT=22
PRODUCTION_SSH_KEY_PATH=
PRODUCTION_APP_PATH=/opt/knesset-site
AUTO_PROMOTE_ANALYSES_TO_PRODUCTION=false
PRODUCTION_SYNC_DEBOUNCE_MS=15000
